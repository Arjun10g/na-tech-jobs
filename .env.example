# Copy to .env and fill in. Never commit .env.

# HuggingFace token with write access to the dataset, model, and Space repos.
HF_TOKEN=

# Discord webhook for ingest/drift/retrain alerts (Phase 0 setup, used everywhere).
DISCORD_WEBHOOK_URL=

# MLflow tracking URI. Default: local SQLite at ./mlruns/mlflow.db
MLFLOW_TRACKING_URI=sqlite:///mlruns/mlflow.db

# Qdrant local storage path. On Spaces this is /data/qdrant.
QDRANT_PATH=./qdrant_storage
